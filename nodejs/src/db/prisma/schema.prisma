generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Status {
  PARADO
  EM_ANDAMENTO
  CONCLUIDA
}

model Tarefa {
  id          Int         @id @default(autoincrement())
  nome        String
  descricao   String?
  status      Status      @default(PARADO)
  categorias  Categoria[] @relation("TarefaParaCategoria")

  @@map("tarefas")
}

model Categoria {
  id      Int      @id @default(autoincrement())
  nome    String
  cor     String
  tarefas Tarefa[] @relation("TarefaParaCategoria")

  @@map("categorias")
}
