generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Status {
  PARADO
  EM_ANDAMENTO
  CONCLUIDA
}

model Tarefa {
  id          Int        @id @default(autoincrement())
  nome        String
  descricao   String?
  status      Status     @default(PARADO)
  categoriaId Int?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id])

  @@map("tarefas")
}

model Categoria {
  id      Int      @id @default(autoincrement())
  nome    String
  cor     String
  tarefas Tarefa[]

  @@map("categorias")
}

